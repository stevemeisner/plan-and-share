{
  "name": "@planshare/cli",
  "version": "0.1.0",
  "description": "CLI tool for pushing markdown plans to PlanShare",
  "type": "module",
  "bin": {
    "plan-push": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "keywords": ["planshare", "markdown", "plans", "cli", "technical-plans", "code-review"],
  "homepage": "https://github.com/stevemeisner/plan-and-share#cli-plan-push",
